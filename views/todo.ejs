<%- include('partials/header', {titulo: info.titulo}); %>
<%- include('partials/navbar', {userData}); %>
<div id="mainAppTodo">
  <div class="d-flex justify-content-center mt-4  ">
    <h2 class="display-4 text-white animate__animated animate__bounceIn">Seguimiento de articulos</h2>
  </div>
  <div class="row p-4">
    <div class="offset-md-2 col-md-8 col-12">
      <div class="card p-4" v-if="!loading">
        <div class="d-flex justify-content-center">
          <p>Ultima actualizacion: <span id="fechaLU">{{ultAct}}</span></p>
        </div>
        <table id="todo-table" class="table table-striped table-bordered">
          <thead>
            <tr>
              <th>Codigo</th>
              <th>Liquidado</th>
              <th>Tipo articulo</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            

              <div v-if="items.length > 0">
                <tr v-for="item in items">
                  <td>{{  item.codigo }}</td>
                  <td v-if="item.liquidado">Liquidado</td>
                  <td v-else>Pendiente</td>
                  <td>{{ item.tipoArticulo }}</td>
                  <!-- <td>{{ = item.observacion }}</td> -->
                  <td>
                    
                    <button type="button" class="btn btn-primary" @click="mostrarModal(item)">
                      imagen                      
                    </button>
                  </td>
                </tr>

              </div>                                           


          </tbody>
        </table>
   
      </div>
      <div v-else class="card">
        <div class="d-flex justify-content-center p-4">          
          <div class="spinner-border" role="status">
            <span class="sr-only">Loading...</span>
          </div>

        </div>
      </div>

    </div>
    <!-- <div class="col-5">
      <form>
        <input type="text" name="item" placeholder="Add new item..." required />
        <button type="submit">Add Item</button>
    </form>
    </div> -->
  </div>  
  <!-- Modal -->
  <div class="modal" id="modal" v-bind:class="[modalShow ? 'show' : '']" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <img id="imgSource" src="" alt="">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>            
        </div>
      </div>
    </div>
  </div>

</div>
<%- include('partials/footer'); %>
<script>
  new Vue({
    el: '#mainAppTodo',
    data: {
      url_img: 'https://res.cloudinary.com/jungoma/image/upload/v1601781044/ohih3abt3cbtwatzytyc.png',
      modalShow: false,
      items: [],
      ultAct: '',
      loading: true
    },
    mounted() {
      let vm = this;
        axios.get('../get-items/')
        .then(function (response) {          
          vm.loading = false;
          vm.items = response.data.data.items;
          vm.ultAct = response.data.data.ultAct;
        })
      },
    methods: {
      mostrarModal: function(item) {
        this.modalShow = !this.modalShow;
        this.url_img = item.img_url;
        $("#modal").modal({
          focus: true
        })
      }
    }
  });

</script>