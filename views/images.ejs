<%- include('partials/header', {titulo: 'Control'}); %>
<%- include('partials/navbar'); %>

<div class="d-flex justify-content-center mt-4">
    <h2 class="display-4 text-white">Control de imagenes</h2>
</div>
<div class="d-flex justify-content-center mt-4">
    <div class="row">
        <Input class="form-control" placeholder="Buscar por codigo"></Input>
    </div>
</div>
<div class="row mt-4">
    <div class="col-12 offset-md-1 col-md-10">
        <div id="mainImages">

            <div class="row">
                <div class="col-3 mb-2" v-for="item in items">
                    <div class="card">
                        <div class="card-body">
                          <p class="card-text font-weight-bold">{{ item.codigo }}</p>
                        </div>
                        <img class="img-fluid" v-bind:src="item.img_url" 
                        width="300" height="300"
                        alt="Card image">
                        <div class="card-body m-0 p-0 pb-1">
                          <!-- <p>{{}}</p> -->
                          <div class="d-flex justify-content-center">                              
                              <button class="btn btn-outline-danger">No</button>
                          </div>
                        </div>
                      </div>
                </div>
                
            </div>
            <nav aria-label="Page navigation example">
                <ul class="pagination">
                  <li class="page-item">
                    <a class="page-link" href="#!" aria-label="Previous">
                      <span aria-hidden="true">&laquo;</span>
                      <span class="sr-only">Previous</span>
                    </a>
                  </li>
                  <li class="page-item"><a class="page-link" href="#!">1</a></li>
                  <li class="page-item"><a class="page-link" href="#!">2</a></li>
                  <li class="page-item"><a class="page-link" href="#!">3</a></li>
                  <li class="page-item">
                    <a class="page-link" href="#!" aria-label="Next">
                      <span aria-hidden="true">&raquo;</span>
                      <span class="sr-only">Next</span>
                    </a>
                  </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
<%- include('partials/footer'); %>
<script src="https://cdn.jsdelivr.net/npm/lodash@4.17.20/lodash.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.20.0/axios.min.js" integrity="sha512-quHCp3WbBNkwLfYUMd+KwBAgpVukJu5MncuQaWXgCrfgcxCJAq/fo+oqrRKOj+UKEmyMCG3tb8RB63W+EmrOBg==" crossorigin="anonymous"></script>
<script src="/js/functions/imagesControl.js"></script>
